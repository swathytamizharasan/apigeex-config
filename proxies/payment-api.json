{
  "openapi": "3.0.0",
  "info": {
    "title": "payment-api",
    "version": "1.0.0",
    "description": "Apigee API: payment-api"
  },
  "paths": {
    "/api/v1/items": {
      "get": {
        "summary": "GET /api/v1/items",
        "operationId": "payment-api_list",
        "x-google-backend": {
          "address": "http://backend.example.com"
        }
      }
    }
  },
  "x-google-auth": {
    "type": "oauth2"
  },
  "x-google-management": {
    "metrics": [
      {
        "name": "requests",
        "display_name": "API Requests",
        "value_type": "INT64",
        "metric_kind": "CUMULATIVE"
      }
    ],
    "quota": {
      "limits": [
        {
          "name": "requests-per-minute",
          "description": "Requests per minute",
          "default_value": 1000,
          "max_value": 1000
        }
      ]
    }
  }
}